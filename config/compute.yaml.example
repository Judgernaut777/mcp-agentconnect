# External local-compute plane configuration (ComputeConnect integration).
#
#   AgentConnect defines the contract; it does NOT own the engine.
#
# This wires an external local-model manager (a ComputeConnect deployment, or any
# server that speaks the six LocalComputeProvider routes) in as one routable worker,
# from config instead of code. The whole subsystem is optional: with nothing set,
# routing simply never sees a `local_model_manager` worker and AgentConnect runs
# exactly as it does standalone.
#
# Precedence (env wins over file for the URL):
#   AGENTCONNECT_COMPUTE_URL (env)  ->  compute.base_url (this file)  ->  off.
# Unlike memory backends, the env URL activates the subsystem even when this
# file says `enabled: false`.
# A malformed `compute:` block degrades to off with a warning — a missing compute
# plane is a smaller problem than a wrong one.
compute:
  enabled: true

  # Base URL of the control plane (GET /health, /models, /models/loaded,
  # POST /route/estimate, /generate, /runs/{id}/cancel). Overridden by
  # AGENTCONNECT_COMPUTE_URL in the environment.
  base_url: http://127.0.0.1:8090

  # Optional request timeout in seconds. Overridden by AGENTCONNECT_COMPUTE_TIMEOUT.
  timeout: 30

  # Optional bearer token, sent verbatim as the Authorization header, never logged.
  # Overridden by AGENTCONNECT_COMPUTE_TOKEN. ComputeConnect v0.1.0 enforces
  # bearer auth when its COMPUTECONNECT_TOKEN is set — the value here must then
  # include the scheme prefix, exactly as below. Prefer the env var so no token
  # hits disk.
  # token: Bearer <token>

  # Optional worker-registration knobs (all have safe defaults in the adapter).
  worker_id: local-manager
  task_type: general
  max_output_tokens: 2048
